{
  "tests": [
    {
      "name": "Register user",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "username": "TestCat99", "email": "testcat99@neko.io", "password": "secret123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login user",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "testcat99@neko.io", "password": "secret123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Empty fields error",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "username": "", "email": "", "password": ""},
      "expectedStatus": 200,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "testcat99@neko.io", "password": "wrongpass"},
      "expectedStatus": 200,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
